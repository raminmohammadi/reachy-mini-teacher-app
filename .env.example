# ─────────────────────────────────────────────────────────────────────────────
# Reachy Mini Local App – environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Mode ─────────────────────────────────────────────────────────────────────
# Choose the AI backend: "gemini" (cloud) or "local" (fully offline)
APP_MODE=gemini

# ── Gemini Live API ───────────────────────────────────────────────────────────
# Required when APP_MODE=gemini
GEMINI_API_KEY=
# Gemini model to use for the Live API (real-time audio + vision)
GEMINI_MODEL=models/gemini-3.1-flash-live-preview

# ── Local LLM – Ollama ────────────────────────────────────────────────────────
# Required when APP_MODE=local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── OpenAI Live API ───────────────────────────────────────────────────────────
# Required when APP_MODE=gemini
OPENAI_API_KEY=

# ── Local STT – Faster-Whisper ────────────────────────────────────────────────
# Model size: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=base
# Compute type: int8 (CPU), float16 (GPU)
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu

# ── Local TTS – Kokoro-ONNX ───────────────────────────────────────────────────
# Voice name (e.g. af_heart, af_bella, bm_george, …)
KOKORO_VOICE=af_heart
# Language code: en-us, en-gb, …
KOKORO_LANG=en-us

# ── Vision (local SmolVLM2) ───────────────────────────────────────────────────
HF_HOME=./cache
LOCAL_VISION_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct
HF_TOKEN=

# ── Profile / personality ─────────────────────────────────────────────────────
# Leave blank for the built-in default profile
REACHY_MINI_CUSTOM_PROFILE=

